APP_NAME="Luxury Store Backend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Production fallback uses MySQL automatically when DB_CONNECTION is missing.
# Production MySQL example:
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=u835925164_ecommerce
# DB_USERNAME=u835925164_ecommerce
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Customer auth and order mailboxes can be configured separately from the admin Saaszo mailbox.
# Both commonly point to Hostinger SMTP when deployed.
# CUSTOMER_SMTP_HOST=smtp.hostinger.com
# CUSTOMER_SMTP_PORT=465
# CUSTOMER_SMTP_ENCRYPTION=ssl
# CUSTOMER_AUTH_FROM_NAME="Little Divinity"
# CUSTOMER_AUTH_FROM_EMAIL=noreply@littledivinity.com
# CUSTOMER_AUTH_REPLY_TO_EMAIL=noreply@littledivinity.com
# CUSTOMER_AUTH_SMTP_USERNAME=noreply@littledivinity.com
# CUSTOMER_AUTH_SMTP_PASSWORD=
# CUSTOMER_ORDER_FROM_NAME="Little Divinity Orders"
# CUSTOMER_ORDER_FROM_EMAIL=order@littledivinity.com
# CUSTOMER_ORDER_REPLY_TO_EMAIL=order@littledivinity.com
# CUSTOMER_ORDER_SMTP_USERNAME=order@littledivinity.com
# CUSTOMER_ORDER_SMTP_PASSWORD=
# STORE_GOOGLE_TAG_MANAGER_ID=
# STORE_FACEBOOK_PIXEL_ID=
# STORE_CUSTOM_HEADER_SCRIPTS=
# STORE_CUSTOM_FOOTER_SCRIPTS=
# RAZORPAY_MERCHANT_ID=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_ACTIVE=false
# RAZORPAY_TEST_MODE=true

# Frontend origins allowed to call this reusable ecommerce API.
# ECOMMERCE_ALLOWED_ORIGINS=https://little-divinity.vercel.app,https://www.littledivinity.com
# ECOMMERCE_ALLOWED_ORIGIN_PATTERNS=/^https?:\/\/.*\.vercel\.app$/

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
